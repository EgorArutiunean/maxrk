[Unit]
Description=maxrk Telegram to MAX bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/maxrk
EnvironmentFile=/opt/maxrk/.env
ExecStart=/opt/maxrk/venv/bin/python /opt/maxrk/app.py
Restart=always
RestartSec=5

# Set your Linux user here
User=YOUR_LINUX_USER
Group=YOUR_LINUX_USER

[Install]
WantedBy=multi-user.target
